# ===== DATABASE =====
POSTGRES_DB=session_manager
POSTGRES_USER=smp_user
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DATABASE_URL=postgresql://smp_user:CHANGE_THIS_STRONG_PASSWORD@postgres:5432/session_manager

# ===== REDIS =====
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_THIS_REDIS_PASSWORD@redis:6379/0

# ===== TELEGRAM BOT =====
BOT_TOKEN=YOUR_MAIN_BOT_TOKEN
BACKUP_BOT_TOKEN=YOUR_BACKUP_BOT_TOKEN
BACKUP_CHAT_ID=YOUR_BACKUP_CHAT_ID
ADMIN_IDS=123456789,987654321

# ===== TELEGRAM API (for Telethon) =====
# Get from https://my.telegram.org
API_ID=YOUR_API_ID
API_HASH=YOUR_API_HASH

# ===== SECURITY =====
JWT_SECRET=CHANGE_THIS_VERY_LONG_RANDOM_SECRET_KEY_MIN_64_CHARS
ENCRYPTION_KEY=CHANGE_THIS_32_CHAR_KEY_FOR_AES256
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD

# ===== API =====
API_HOST=0.0.0.0
API_PORT=8000
API_URL=http://api:8000

# ===== PAYMENT =====
# USDT TRC20 wallet
USDT_TRC20_WALLET=YOUR_USDT_TRC20_ADDRESS
# TON wallet
TON_WALLET=YOUR_TON_WALLET_ADDRESS
# TRON wallet
TRX_WALLET=YOUR_TRX_WALLET_ADDRESS

# ===== SETTINGS =====
MAX_SESSIONS_PER_WORKER=500
JOIN_DELAY_MIN=3
JOIN_DELAY_MAX=8
FLOOD_WAIT_MULTIPLIER=1.5
PROXY_ROTATION=true
LOG_LEVEL=INFO
