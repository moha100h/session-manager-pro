# ================================================================
# Session Manager Pro — Environment Variables
# کپی این فایل به .env و مقادیر را تنظیم کنید
# ================================================================

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_DB=session_manager
POSTGRES_USER=smuser
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DATABASE_URL=postgresql://smuser:CHANGE_ME_STRONG_PASSWORD_HERE@postgres:5432/session_manager

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── API (FastAPI) ──────────────────────────────────────────────
# JWT secret — حداقل 32 کاراکتر تصادفی
JWT_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
JWT_EXPIRE_HOURS=720

# کلید رمزنگاری سشن‌ها — دقیقاً 32 کاراکتر
ENCRYPTION_KEY=CHANGE_ME_EXACTLY_32_CHARS_HERE!!

# ── Admin ──────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# ── Telegram Bot ───────────────────────────────────────────────
BOT_TOKEN=YOUR_BOT_TOKEN_FROM_BOTFATHER
# آیدی عددی ادمین‌ها (با کاما جدا کنید)
ADMIN_IDS=123456789,987654321

# ── Telegram API (برای Telethon) ───────────────────────────────
# از https://my.telegram.org/apps دریافت کنید
API_ID=12345678
API_HASH=your_api_hash_here

# ── Worker ─────────────────────────────────────────────────────
CHECK_INTERVAL_MINUTES=30
LOG_LEVEL=INFO

# ── Web Panel ──────────────────────────────────────────────────
# آدرس API برای React (در production خالی بگذارید — nginx پروکسی می‌کند)
REACT_APP_API_URL=

# ── Backup Bot ─────────────────────────────────────────────────
BACKUP_BOT_TOKEN=YOUR_BACKUP_BOT_TOKEN
BACKUP_CHAT_ID=-1001234567890
BACKUP_INTERVAL_HOURS=1

# ── Wallet Addresses (برای دریافت پرداخت) ─────────────────────
USDT_TRC20_WALLET=YOUR_USDT_TRC20_ADDRESS
TON_WALLET=YOUR_TON_WALLET_ADDRESS
TRX_WALLET=YOUR_TRX_WALLET_ADDRESS

# ── Nginx ──────────────────────────────────────────────────────
# دامنه یا IP سرور شما
DOMAIN=your-domain.com
