# ===== دیتابیس =====
POSTGRES_DB=session_manager
POSTGRES_USER=smp_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ===== Redis =====
REDIS_URL=redis://redis:6379

# ===== امنیت =====
# با دستور: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING
JWT_EXPIRE_HOURS=720

# با دستور: openssl rand -hex 16
ENCRYPTION_KEY=CHANGE_ME_32_CHAR_KEY

# ===== ادمین پنل =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# ===== بات تلگرام اصلی =====
# از @BotFather بگیرید
BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff1234567890

# آیدی عددی تلگرام ادمین‌ها (با کاما جدا کنید)
ADMIN_IDS=123456789,987654321

# ===== بات بکاپ =====
# یک بات جداگانه از @BotFather بسازید
BACKUP_BOT_TOKEN=0987654321:ZZYYXXWWVVUUzzyyxxwwvvuu0987654321

# آیدی چت یا کانال برای دریافت بکاپ
BACKUP_CHAT_ID=-1001234567890

# فاصله بکاپ (ساعت) — پیش‌فرض: 1
BACKUP_INTERVAL_HOURS=1

# ===== Telegram API =====
# از my.telegram.org بگیرید
API_ID=12345678
API_HASH=abcdef1234567890abcdef1234567890

# ===== کیف پول‌های دریافت پرداخت =====
USDT_TRC20_WALLET=TYourUSDTWalletAddressHere
TON_WALLET=UQYourTONWalletAddressHere
TRX_WALLET=TYourTRXWalletAddressHere

# ===== تنظیمات Worker =====
MAX_SESSIONS_PER_WORKER=500
LOG_LEVEL=INFO
